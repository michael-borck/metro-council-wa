{% extends "base.html.j2" %}

{% block title %}Staff login — Metro Council WA{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap-narrow">
        <p class="eyebrow">Staff portal</p>
        <h1 style="margin-bottom: var(--mc-px-5);">Sign in.</h1>
        <p class="lead" style="margin-bottom: var(--mc-px-6);">Metro Council staff only. Enter your work email and we will send you a 6-digit access code.</p>

        <form id="login-form" style="max-width: 480px; display: grid; gap: var(--mc-px-3); border: var(--mc-border); box-shadow: var(--mc-shadow); padding: var(--mc-px-5); background: var(--mc-bg);">
            <label class="label" for="email">Work email</label>
            <input type="email" id="email" name="email" required placeholder="firstname.lastname@metrocouncilwa.gov.au" style="padding: var(--mc-px-3); background: var(--mc-bg); border: var(--mc-border-thin); color: var(--mc-text); font-family: var(--mc-font-body); font-size: 1rem;">
            <button type="submit" class="btn btn-primary btn-arrow">Send code</button>
            <p class="label" style="margin-top: var(--mc-px-2);">Authentication coming soon — placeholder for the WorkReady simulation.</p>
        </form>
    </div>
</section>
{% endblock %}
