<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Metro Council WA — Local Government Services{% endblock %}</title>
    <meta name="description" content="{% block description %}Metro Council WA delivers local government services to 85,000 residents across 12 inner and middle Perth suburbs. Pay rates, report issues, apply for permits, find services.{% endblock %}">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="stylesheet" href="/styles/main.css">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <div class="alert-banner" role="region" aria-label="Service alert">
        <div class="alert-banner-inner">
            <span class="alert-banner-tag">Notice</span>
            <span>Council offices closed Monday 27 April for ANZAC Day. Online services available 24/7.</span>
            <a href="/services.html">View all services</a>
        </div>
    </div>

    <header class="header">
        <div class="header-inner">
            <a href="/" class="brand">
                <div class="brand-crest">MC</div>
                <div class="brand-name">
                    <strong>Metro Council WA</strong>
                    <span>Local Government / Perth WA</span>
                </div>
            </a>
            <nav class="nav" aria-label="Primary">
                <a href="/" class="{% if page == 'index' %}active{% endif %}">Home</a>
                <a href="/services.html" class="{% if page == 'services' %}active{% endif %}">Services</a>
                <a href="/council.html" class="{% if page == 'council' %}active{% endif %}">Your Council</a>
                <a href="/about.html" class="{% if page == 'about' %}active{% endif %}">About</a>
                <a href="/careers.html" class="{% if page == 'careers' %}active{% endif %}">Careers</a>
                <a href="/contact.html" class="nav-cta">Contact us</a>
            </nav>
        </div>
    </header>

    <main id="main">
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>Metro Council WA</h3>
                <p>Delivering local government services to 85,000 residents across 12 suburbs in inner and middle Perth.</p>
                <p class="footer-acknowledgement">Metro Council WA acknowledges the Whadjuk people of the Noongar nation as the Traditional Custodians of the lands on which we work, and we pay our respects to Elders past and present.</p>
            </div>
            <div class="footer-col">
                <h4>Services</h4>
                <ul>
                    <li><a href="/services.html">All services</a></li>
                    <li><a href="/services.html">Pay your rates</a></li>
                    <li><a href="/services.html">Report an issue</a></li>
                    <li><a href="/services.html">Planning applications</a></li>
                    <li><a href="/services.html">Bin collection</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Council</h4>
                <ul>
                    <li><a href="/council.html">Elected members</a></li>
                    <li><a href="/council.html">Meeting calendar</a></li>
                    <li><a href="/council.html">Have your say</a></li>
                    <li><a href="/about.html">About council</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>For Staff</h4>
                <ul>
                    <li><a href="/staff/">Staff portal</a></li>
                    <li><a href="/staff/directory.html">Directory</a></li>
                    <li><a href="/staff/documents.html">Documents</a></li>
                    <li><a href="/careers.html">Open roles</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {{ year }} Metro Council WA / ABN 00 000 000 000 / WA Local Government Authority</p>
            <p class="footer-disclaimer">A fictional council, made for a Curtin University internship simulation.</p>
        </div>
    </footer>
</body>
</html>
