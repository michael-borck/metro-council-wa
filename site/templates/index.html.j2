{% extends "base.html.j2" %}

{% block title %}Metro Council WA — Serving Our Community, Shaping Our Future{% endblock %}

{% block content %}
<section class="hero">
    <div class="hero-inner">
        <div>
            <p class="eyebrow">Local government / 85,000 residents / 12 suburbs</p>
            <h1>
                Your council.<br>
                <span class="accent">Your services.</span>
            </h1>
            <p class="hero-tagline">{{ company.tagline or "Serving our community, shaping our future." }} Find a service, pay your rates, report a problem, or have your say. We're working to make council easier to deal with — online and in person.</p>

            <div class="hero-search">
                <label class="hero-search-label" for="site-search">What do you need to do today?</label>
                <div class="hero-search-input">
                    <input type="search" id="site-search" placeholder="e.g. report a pothole, pay rates, bin day" aria-label="Search council services">
                    <button type="button">Search</button>
                </div>
                <p class="hero-search-popular"><strong>Popular:</strong> <a href="/services.html">Pay rates</a> <a href="/services.html">Bin day</a> <a href="/services.html">Plan a build</a> <a href="/services.html">Book a hall</a></p>
            </div>
        </div>

        <aside class="now-panel" aria-label="Council status today">
            <h3>Today at a glance</h3>
            <div class="now-row">
                <span>Council offices</span>
                <span class="pill pill-open">Open until 5pm</span>
            </div>
            <div class="now-row">
                <span>Library — main</span>
                <span class="pill pill-open">Open until 8pm</span>
            </div>
            <div class="now-row">
                <span>Aquatic centre</span>
                <span class="pill pill-open">Open until 9pm</span>
            </div>
            <div class="now-row">
                <span>Bin day this week</span>
                <strong>Tue / Fri</strong>
            </div>
            <div class="now-row">
                <span>Next council meeting</span>
                <strong>Tue 6pm</strong>
            </div>
            <div class="now-row">
                <span>Open consultations</span>
                <span class="pill pill-warn">3 active</span>
            </div>
        </aside>
    </div>
</section>

<section class="actions-section" aria-labelledby="actions-heading">
    <div class="wrap">
        <div class="actions-header">
            <div>
                <p class="eyebrow">I want to…</p>
                <h2 id="actions-heading">Common things people do here.</h2>
            </div>
            <a href="/services.html" class="btn btn-ghost btn-arrow">All services</a>
        </div>

        <div class="actions-grid">
            <a href="/services.html" class="action">
                <div class="action-icon">$</div>
                <div class="action-title">Pay my rates online</div>
                <div class="action-meta">Takes about 2 minutes</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">!</div>
                <div class="action-title">Report a problem in my street</div>
                <div class="action-meta">Pothole, graffiti, bin, light</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">▣</div>
                <div class="action-title">Find my bin collection day</div>
                <div class="action-meta">Type your address</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">⌂</div>
                <div class="action-title">Plan a renovation or build</div>
                <div class="action-meta">Permits and approvals</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">♣</div>
                <div class="action-title">Book a park or community hall</div>
                <div class="action-meta">Functions, sport, events</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">📖</div>
                <div class="action-title">Borrow from the library</div>
                <div class="action-meta">2 branches, 24/7 returns</div>
            </a>
            <a href="/council.html" class="action">
                <div class="action-icon">✍</div>
                <div class="action-title">Have my say on a proposal</div>
                <div class="action-meta">3 open consultations</div>
            </a>
            <a href="/services.html" class="action">
                <div class="action-icon">♻</div>
                <div class="action-title">Recycle or get rid of bulk waste</div>
                <div class="action-meta">Collections and tip vouchers</div>
            </a>
        </div>
    </div>
</section>

<section class="facts-bar">
    <div class="facts-grid">
        <div class="fact">
            <div class="fact-num">85,000<span class="unit">residents</span></div>
            <div class="fact-label">Across 12 suburbs</div>
        </div>
        <div class="fact">
            <div class="fact-num">320<span class="unit">staff</span></div>
            <div class="fact-label">Indoor &amp; outdoor crews</div>
        </div>
        <div class="fact">
            <div class="fact-num">2,400<span class="unit">/yr</span></div>
            <div class="fact-label">Planning applications</div>
        </div>
        <div class="fact">
            <div class="fact-num">$95<span class="unit">m</span></div>
            <div class="fact-label">Annual operating revenue</div>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap">
        <div class="section-header">
            <p class="eyebrow">News and notices</p>
            <h2>What's happening this month.</h2>
            <p class="lead">Service updates, consultation openings, and the things you might want to know about your council.</p>
        </div>

        <div class="notice-grid">
            <article class="notice">
                <span class="notice-tag tag-gold">Consultation</span>
                <h3>Density code review — have your say.</h3>
                <p>The state government has released new residential density guidelines. Council is consulting on how these apply locally. Two community forums plus an online submission form.</p>
                <div class="notice-foot">
                    <span>Closes 15 May</span>
                    <a href="/council.html">Read more →</a>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag tag-green">Service update</span>
                <h3>Online citizen portal — phase two live.</h3>
                <p>You can now pay rates, request bulk waste collection, and submit minor works applications online. Phase three (planning portal) is coming in July.</p>
                <div class="notice-foot">
                    <span>Released 12 April</span>
                    <a href="/services.html">Try it →</a>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag">News</span>
                <h3>Food waste trial expanding to 2,000 homes.</h3>
                <p>The food waste composting trial is expanding after a successful first phase. Eligible households will receive a kerbside caddy from May.</p>
                <div class="notice-foot">
                    <span>Released 8 April</span>
                    <a href="/services.html">Read more →</a>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="section-pad" style="background: var(--mc-bg-2); border-top: 4px solid var(--mc-text); border-bottom: 4px solid var(--mc-text);">
    <div class="wrap">
        <div class="decision-block">
            <h3>Digital first, community always.</h3>
            <p>{{ (scenario.description or "")|trim }}</p>

            {% if scenario.key_tensions %}
            <ul class="tensions-grid">
                {% for tension in scenario.key_tensions[:6] %}
                <li>{{ tension }}</li>
                {% endfor %}
            </ul>
            {% endif %}
        </div>
    </div>
</section>

<section class="have-your-say">
    <div class="have-your-say-inner">
        <div>
            <h2>Have your <span class="highlight">say.</span></h2>
            <p>Council decisions are better when residents are part of them. We have three open consultations right now — submit a comment online, attend a forum, or write to your local councillor.</p>
        </div>
        <a href="/council.html" class="btn btn-gold btn-arrow have-your-say-btn">View consultations</a>
    </div>
</section>
{% endblock %}
