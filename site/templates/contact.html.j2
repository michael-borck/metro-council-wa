{% extends "base.html.j2" %}

{% block title %}Contact us — Metro Council WA{% endblock %}

{% block content %}
<section class="hero" style="padding: var(--mc-px-6) 0;">
    <div class="hero-inner" style="grid-template-columns: 1fr;">
        <div>
            <p class="eyebrow">Contact council</p>
            <h1 style="max-width: 18ch;">Talk to <span class="accent">your council.</span></h1>
            <p class="hero-tagline" style="max-width: 60ch;">Most things can be done online — but if you need to speak to a person, here's how. Our customer service team is open Monday to Friday, 8:30am to 5:00pm.</p>
        </div>
    </div>
</section>

<section class="actions-section">
    <div class="wrap">
        <div class="actions-header">
            <div>
                <p class="eyebrow">How to reach us</p>
                <h2>Five ways to contact council.</h2>
            </div>
        </div>

        <div class="notice-grid">
            <article class="notice">
                <span class="notice-tag tag-green">Phone</span>
                <h3>Customer service</h3>
                <p>Our friendly customer service team can help with most enquiries — rates, bins, parking, planning, services, complaints.</p>
                <div class="notice-foot">
                    <span><strong>(08) 9000 0000</strong></span>
                    <span>Mon–Fri 8:30–5:00</span>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag tag-gold">After hours</span>
                <h3>Emergencies</h3>
                <p>Fallen trees, water leaks, dangerous road hazards, and other urgent matters outside business hours.</p>
                <div class="notice-foot">
                    <span><strong>1800 000 000</strong></span>
                    <span>24 / 7</span>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag">Online</span>
                <h3>Citizen portal</h3>
                <p>Pay rates, report issues, request services, submit applications, and track progress on requests you've already made.</p>
                <div class="notice-foot">
                    <span>portal.metrocouncilwa.gov.au</span>
                    <a href="#">Visit →</a>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag">Email</span>
                <h3>General enquiries</h3>
                <p>For non-urgent matters and written records. Replies within two business days.</p>
                <div class="notice-foot">
                    <span><strong>council@metrocouncilwa.gov.au</strong></span>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag">In person</span>
                <h3>Civic Centre</h3>
                <p>Drop in to our customer service counter at the Civic Centre. Most matters can be handled at the counter; complex matters by appointment.</p>
                <div class="notice-foot">
                    <span>10 Council Way, Perth</span>
                    <span>Mon–Fri 8:30–5:00</span>
                </div>
            </article>
            <article class="notice">
                <span class="notice-tag tag-gold">Translation</span>
                <h3>Need an interpreter?</h3>
                <p>Free interpreting available through TIS National. Translated information is available in multiple languages on request.</p>
                <div class="notice-foot">
                    <span><strong>131 450</strong></span>
                    <span>TIS National</span>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap-narrow">
        <p class="eyebrow">Accessibility</p>
        <h2 style="margin-bottom: var(--mc-px-3);">If you need help with this website.</h2>
        <p style="color: var(--mc-text-muted); font-size: 1.1rem; line-height: 1.75;">Metro Council aims to meet WCAG 2.1 AA accessibility standards. If you have trouble using this site, find content you can't read, or need information in an alternative format (large print, audio, plain language), please contact us by phone or email and we'll get it to you.</p>
    </div>
</section>
{% endblock %}
