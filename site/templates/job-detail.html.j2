{% extends "base.html.j2" %}

{% block title %}{{ job.title }} — Metro Council WA{% endblock %}

{% block content %}
<section class="hero" style="padding: var(--mc-px-6) 0;">
    <div class="hero-inner" style="grid-template-columns: 1fr;">
        <div>
            <p class="eyebrow"><a href="/careers.html" style="color: var(--mc-green-2);">← All open positions</a></p>
            <h1 style="max-width: 22ch;">{{ job.title }}</h1>
            <p class="hero-tagline" style="max-width: 60ch;">{{ job.brief or job.summary or "" }}</p>
        </div>
    </div>
</section>

<section class="actions-section">
    <div class="wrap">
        <div class="notice-grid" style="grid-template-columns: repeat(4, 1fr);">
            <article class="notice">
                <span class="notice-tag">Department</span>
                <h3 style="font-size: 1.15rem;">{{ job.department or "—" }}</h3>
            </article>
            <article class="notice">
                <span class="notice-tag tag-green">Type</span>
                <h3 style="font-size: 1.15rem;">{{ job.employment_type or "Full-time" }}</h3>
            </article>
            {% if job.reports_to %}
            <article class="notice">
                <span class="notice-tag">Reports to</span>
                <h3 style="font-size: 1.15rem;">{{ job.reports_to }}</h3>
            </article>
            {% endif %}
            <article class="notice">
                <span class="notice-tag tag-gold">Location</span>
                <h3 style="font-size: 1.15rem;">Perth WA</h3>
            </article>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap-narrow">
        {% if job.description %}
        <article class="prose">
            {{ job.description | markdown }}
        </article>
        {% endif %}
    </div>
</section>

<section class="apply-section" id="apply">
    <div class="wrap">
        <p class="eyebrow">Apply for this role</p>
        <h2>Sound like the right <span class="highlight">role for you?</span></h2>
        <p class="hero-tagline">Submit your CV and a short response addressing the selection criteria. We acknowledge every application within two business days.</p>

        <form id="apply-form" class="apply-form" data-api-base="https://workready-api.eduserver.au">
            <input type="hidden" name="posting_id" value="">
            <input type="hidden" name="job_title" value="{{ job.title }}">
            <div>
                <label for="applicant_name">Full name <span class="apply-required">*</span></label>
                <input type="text" name="applicant_name" id="applicant_name" required>
            </div>
            <div>
                <label for="applicant_email">Email address <span class="apply-required">*</span></label>
                <input type="email" name="applicant_email" id="applicant_email" required placeholder="firstname.lastname@student.curtin.edu.au">
            </div>
            <div>
                <label for="cover_letter">Cover letter</label>
                <textarea name="cover_letter" id="cover_letter" rows="5" placeholder="Tell us why you're a good fit for this role…"></textarea>
            </div>
            <div>
                <label for="resume">Resume (PDF) <span class="apply-required">*</span></label>
                <input type="file" name="resume" id="resume" accept=".pdf" required>
            </div>
            <div>
                <button type="submit" class="btn btn-primary btn-arrow">Submit application</button>
            </div>
            <div id="apply-result" class="apply-result"></div>
        </form>
    </div>
</section>
{% endblock %}

{% block head_extra %}
<script src="/scripts/apply.js" defer></script>
{% endblock %}
